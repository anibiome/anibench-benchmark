{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://anibench.org/schemas/v2/design-input.schema.json",
    "title": "AniBench v2 prospective or completed trial design input",
    "description": "Normal-human input contract for compiling source-honest trial-design coordinates without a composite or ordinal output.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "contract",
        "assessment_lane",
        "study_id",
        "name",
        "population",
        "duration",
        "policy_arms",
        "randomized_policy",
        "concurrent_control",
        "adaptive_reassignment",
        "within_policy_randomized",
        "operator_families",
        "measurement_modules"
    ],
    "properties": {
        "contract": {"const": "anibench.design-input.v2-candidate1"},
        "assessment_lane": {"enum": ["design_preview", "registered", "realized", "accessible", "demonstrated"]},
        "study_id": {"$ref": "#/$defs/id"},
        "name": {"type": "string", "minLength": 1, "maxLength": 240},
        "population": {"$ref": "#/$defs/typed_positive_integer"},
        "duration": {
            "allOf": [{"$ref": "#/$defs/typed_positive_integer"}],
            "description": "Duration in days. Semantics names the exact clock, such as intervention_duration_days or total_followup_days."
        },
        "policy_arms": {
            "type": ["integer", "null"],
            "minimum": 1,
            "description": "Declared policy-arm count, or null when it is not established."
        },
        "randomized_policy": {"$ref": "#/$defs/tri_state_boolean"},
        "concurrent_control": {"$ref": "#/$defs/tri_state_boolean"},
        "adaptive_reassignment": {"$ref": "#/$defs/tri_state_boolean"},
        "within_policy_randomized": {"$ref": "#/$defs/tri_state_boolean"},
        "operator_families": {
            "type": "array",
            "items": {"$ref": "#/$defs/id"},
            "uniqueItems": true
        },
        "measurement_modules": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/measurement_module"}
        }
    },
    "$defs": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
        "tri_state_boolean": {
            "type": ["boolean", "null"],
            "description": "True, false, or null when the source does not establish the field."
        },
        "evidence_state": {"enum": ["exact", "conditional", "unknown"]},
        "typed_positive_integer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "state", "semantics"],
            "properties": {
                "value": {"type": ["integer", "null"], "minimum": 1},
                "state": {"$ref": "#/$defs/evidence_state"},
                "semantics": {"$ref": "#/$defs/id"}
            }
        },
        "measurement_module": {
            "type": "object",
            "additionalProperties": false,
            "required": ["module_id", "label", "evidence_state", "events_per_participant"],
            "properties": {
                "module_id": {"$ref": "#/$defs/id"},
                "label": {"type": "string", "minLength": 1, "maxLength": 160},
                "evidence_state": {"$ref": "#/$defs/evidence_state"},
                "events_per_participant": {
                    "type": ["integer", "null"],
                    "minimum": 1,
                    "description": "Declared scheduled or realized measurement events for one participant; null when not established."
                }
            }
        }
    },
    "x-semantic-constraints": [
        "population and duration use null exactly when state is unknown",
        "measurement modules with unknown evidence state use null events_per_participant",
        "module_id and case-folded operator-family identifiers are unique",
        "randomized_policy=true and concurrent_control=true each require at least two declared policy arms",
        "no missing coordinate is imputed"
    ]
}

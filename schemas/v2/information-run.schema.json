{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anibench.org/schemas/v2/information-run.schema.json",
  "title": "AniBench v2 joint-information candidate run",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "benchmark_suite_version", "lane", "parameter_space_hash", "prior_metric_hash", "reference_level_hash", "event_manifest_hash", "intervention_design_hash", "uncertainty_model_hash", "reference_authority_id", "matrix_hashes", "information_matrix", "prior_precision", "reference_information", "reference_direction_basis", "source_objects"],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"},
    "matrix": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 1, "items": {"type": "number"}}}
  },
  "properties": {
    "contract": {"const": "anibench.information-run.v2-candidate1"},
    "benchmark_suite_version": {"type": "string", "minLength": 1},
    "lane": {"enum": ["design_preview", "registered", "realized", "accessible", "demonstrated"]},
    "parameter_space_hash": {"$ref": "#/$defs/sha256"},
    "prior_metric_hash": {"$ref": "#/$defs/sha256"},
    "reference_level_hash": {"$ref": "#/$defs/sha256"},
    "event_manifest_hash": {"$ref": "#/$defs/sha256"},
    "intervention_design_hash": {"$ref": "#/$defs/sha256"},
    "uncertainty_model_hash": {"$ref": "#/$defs/sha256"},
    "reference_authority_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Caller-declared authority handle. It creates no trust; the server derives recognition against its local registry."
    },
    "matrix_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["information_matrix_sha256", "prior_precision_matrix_sha256", "reference_information_matrix_sha256", "reference_direction_basis_sha256"],
      "properties": {
        "information_matrix_sha256": {"$ref": "#/$defs/sha256"},
        "prior_precision_matrix_sha256": {"$ref": "#/$defs/sha256"},
        "reference_information_matrix_sha256": {"$ref": "#/$defs/sha256"},
        "reference_direction_basis_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "information_matrix": {"$ref": "#/$defs/matrix"},
    "prior_precision": {"$ref": "#/$defs/matrix"},
    "reference_information": {"$ref": "#/$defs/matrix"},
    "reference_direction_basis": {
      "$ref": "#/$defs/matrix",
      "description": "Column-orthonormal direction basis, expressed after prior whitening, that diagonalizes the frozen reference information. It removes eigenvector ambiguity when reference eigenvalues repeat."
    },
    "source_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["object_id", "sha256"],
        "properties": {"object_id": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
      }
    }
  },
  "x-semantic-constraints": [
    "all four matrices are finite, square, and have the same dimension",
    "each declared matrix hash equals the server-computed canonical numeric-matrix hash",
    "prior_precision is positive definite",
    "information_matrix and reference_information are positive semidefinite",
    "reference_direction_basis is column-orthonormal and diagonalizes prior-whitened reference_information",
    "reference_authority_id is caller input only and cannot establish local authority"
  ]
}

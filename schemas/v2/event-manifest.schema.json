{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anibench.org/schemas/v2/event-manifest.schema.json",
  "title": "AniBench v2 participant-event manifest",
  "description": "Aggregate, privacy-preserving event geometry for joint biological information construction. Pairwise flags cannot substitute for participant-event hyperedges.",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "event_manifest_id",
    "study_id",
    "lane",
    "parameter_space_id",
    "parameter_space_sha256",
    "uncertainty_model_id",
    "uncertainty_model_sha256",
    "source_manifest_sha256",
    "created_at",
    "participant_sets",
    "time_bases",
    "measurement_modules",
    "event_types",
    "joint_event_hyperedges",
    "covariance_groups",
    "source_receipts",
    "public_score_emission_permitted"
  ],
  "properties": {
    "schema_version": {"const": "anibench.event-manifest.v2"},
    "contract_version": {"type": "string", "pattern": "^2\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"},
    "event_manifest_id": {"$ref": "#/$defs/id"},
    "study_id": {"$ref": "#/$defs/id"},
    "lane": {"enum": ["design", "realized", "accessible", "demonstrated"]},
    "parameter_space_id": {"$ref": "#/$defs/id"},
    "parameter_space_sha256": {"$ref": "#/$defs/sha256"},
    "uncertainty_model_id": {"$ref": "#/$defs/id"},
    "uncertainty_model_sha256": {"$ref": "#/$defs/sha256"},
    "intervention_design_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"},
    "intervention_design_sha256": {
      "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "source_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "created_at": {"type": "string", "format": "date-time"},
    "participant_sets": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/participant_set"}
    },
    "time_bases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/time_basis"}
    },
    "measurement_modules": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/measurement_module"}
    },
    "event_types": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/event_type"}
    },
    "joint_event_hyperedges": {
      "type": "array",
      "items": {"$ref": "#/$defs/joint_event_hyperedge"}
    },
    "covariance_groups": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/covariance_group"}
    },
    "source_receipts": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_receipt"}
    },
    "semantic_constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "public_score_emission_permitted": {"const": false}
  },
  "additionalProperties": false,
  "x-semantic-constraints": [
    "all referenced IDs exist in this manifest or its bound uncertainty model",
    "IDs are unique within each collection",
    "intervention_design_id and intervention_design_sha256 are both null or both non-null",
    "joint participant and event counts do not exceed every referenced marginal set",
    "one physical measurement lineage contributes at most once to one joint information event"
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{1,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "coordinate_ref": {
      "$ref": "https://anibench.org/schemas/v2/uncertainty.schema.json#/$defs/coordinate_ref"
    },
    "participant_set": {
      "type": "object",
      "required": [
        "participant_set_id",
        "definition",
        "count",
        "sampling_frame",
        "source_receipt_ids"
      ],
      "properties": {
        "participant_set_id": {"$ref": "#/$defs/id"},
        "parent_participant_set_id": {"type": ["string", "null"]},
        "definition": {"type": "string", "minLength": 1},
        "count": {"$ref": "#/$defs/coordinate_ref"},
        "sampling_frame": {
          "enum": [
            "protocol_target",
            "enrolled",
            "retained",
            "assayed",
            "contrast_supported",
            "decision_eligible",
            "analysis_complete"
          ]
        },
        "strata": {
          "type": "array",
          "items": {"$ref": "#/$defs/stratum"}
        },
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "stratum": {
      "type": "object",
      "required": ["axis_id", "level_id", "count"],
      "properties": {
        "axis_id": {"$ref": "#/$defs/id"},
        "level_id": {"$ref": "#/$defs/id"},
        "count": {"$ref": "#/$defs/coordinate_ref"}
      },
      "additionalProperties": false
    },
    "time_basis": {
      "type": "object",
      "required": [
        "time_basis_id",
        "origin",
        "calendar_unit",
        "schedule_semantics",
        "source_receipt_ids"
      ],
      "properties": {
        "time_basis_id": {"$ref": "#/$defs/id"},
        "origin": {
          "enum": [
            "enrollment",
            "randomization",
            "intervention_start",
            "decision_time",
            "specimen_collection",
            "absolute_calendar"
          ]
        },
        "calendar_unit": {"enum": ["second", "minute", "hour", "day", "week", "month"]},
        "schedule_semantics": {
          "enum": ["exact_offsets", "windowed_offsets", "rate_process", "irregular_realized"]
        },
        "offset_coordinate_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "measurement_module": {
      "type": "object",
      "required": [
        "measurement_module_id",
        "modality_registry_id",
        "information_role",
        "feature_ancestry_id",
        "target_count",
        "technical_quality",
        "completeness",
        "standardization",
        "measurement_error_scale",
        "covariance_group_id",
        "event_type_ids",
        "source_receipt_ids"
      ],
      "properties": {
        "measurement_module_id": {"$ref": "#/$defs/id"},
        "modality_registry_id": {"$ref": "#/$defs/id"},
        "information_role": {
          "enum": [
            "biological_anchor",
            "direct_function",
            "digital_observer",
            "exposure",
            "context",
            "clinical_endpoint"
          ]
        },
        "feature_ancestry_id": {"$ref": "#/$defs/id"},
        "specimen_or_signal": {"type": "string", "minLength": 1},
        "tissues_or_compartments": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "cell_resolution": {
          "enum": ["bulk", "cell_enriched", "single_cell", "spatial", "not_applicable", "unspecified"]
        },
        "platform_id": {"type": ["string", "null"]},
        "target_count": {"$ref": "#/$defs/coordinate_ref"},
        "technical_quality": {"$ref": "#/$defs/coordinate_ref"},
        "completeness": {"$ref": "#/$defs/coordinate_ref"},
        "standardization": {"$ref": "#/$defs/coordinate_ref"},
        "measurement_error_scale": {"$ref": "#/$defs/coordinate_ref"},
        "covariance_group_id": {"$ref": "#/$defs/id"},
        "batch_group_id": {"type": ["string", "null"]},
        "event_type_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "event_type": {
      "type": "object",
      "required": [
        "event_type_id",
        "event_role",
        "participant_set_id",
        "time_basis_id",
        "events_per_participant",
        "observation_span",
        "measurement_module_ids",
        "identity_linkage",
        "time_linkage",
        "source_receipt_ids"
      ],
      "properties": {
        "event_type_id": {"$ref": "#/$defs/id"},
        "event_role": {
          "enum": [
            "baseline",
            "observation",
            "decision",
            "intervention_exposure",
            "outcome",
            "followup",
            "washout",
            "withdrawal",
            "safety"
          ]
        },
        "participant_set_id": {"$ref": "#/$defs/id"},
        "time_basis_id": {"$ref": "#/$defs/id"},
        "events_per_participant": {"$ref": "#/$defs/coordinate_ref"},
        "observation_span": {"$ref": "#/$defs/coordinate_ref"},
        "measurement_module_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "assignment_stage_id": {"type": ["string", "null"]},
        "identity_linkage": {"$ref": "#/$defs/coordinate_ref"},
        "time_linkage": {"$ref": "#/$defs/coordinate_ref"},
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "joint_event_hyperedge": {
      "type": "object",
      "required": [
        "hyperedge_id",
        "participant_set_ids",
        "event_type_ids",
        "measurement_module_ids",
        "joint_participant_count",
        "joint_event_count",
        "identity_linkage",
        "temporal_compatibility",
        "specimen_lineage_linkage",
        "intersection_semantics",
        "ancestry_group_id",
        "source_receipt_ids"
      ],
      "properties": {
        "hyperedge_id": {"$ref": "#/$defs/id"},
        "participant_set_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "event_type_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "measurement_module_ids": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "joint_participant_count": {"$ref": "#/$defs/coordinate_ref"},
        "joint_event_count": {"$ref": "#/$defs/coordinate_ref"},
        "identity_linkage": {"$ref": "#/$defs/coordinate_ref"},
        "temporal_compatibility": {"$ref": "#/$defs/coordinate_ref"},
        "specimen_lineage_linkage": {"$ref": "#/$defs/coordinate_ref"},
        "compatible_time_window": {"$ref": "#/$defs/coordinate_ref"},
        "intersection_semantics": {
          "enum": ["exact_intersection", "lower_bound", "estimated", "protocol_planned"]
        },
        "ancestry_group_id": {"$ref": "#/$defs/id"},
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "covariance_group": {
      "type": "object",
      "required": [
        "covariance_group_id",
        "member_measurement_module_ids",
        "covariance_semantics",
        "covariance_asset_sha256",
        "source_receipt_ids"
      ],
      "properties": {
        "covariance_group_id": {"$ref": "#/$defs/id"},
        "member_measurement_module_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "covariance_semantics": {
          "enum": ["protocol_prior", "empirical_realized", "perfect_duplicate", "independence_bound", "unknown"]
        },
        "covariance_asset_sha256": {
          "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
        },
        "source_receipt_ids": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "source_receipt": {
      "type": "object",
      "required": ["source_receipt_id", "sha256", "locator", "authority"],
      "properties": {
        "source_receipt_id": {"$ref": "#/$defs/id"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "locator": {"type": "string", "minLength": 1},
        "authority": {
          "enum": ["protocol", "registry", "dataset", "independent_attestation"]
        }
      },
      "additionalProperties": false
    }
  }
}
